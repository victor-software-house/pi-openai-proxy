{
	"name": "@pi-openai-proxy/pi-extension",
	"version": "0.0.1",
	"description": "Pi extension for pi-proxy: /proxy command family with config panel",
	"license": "MIT",
	"author": "Victor Software House",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/victor-software-house/pi-openai-proxy.git",
		"directory": "packages/pi-extension"
	},
	"publishConfig": {
