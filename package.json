{
	"name": "@victor-software-house/pi-openai-proxy",
	"version": "4.6.0",
	"description": "OpenAI-compatible HTTP proxy for pi's multi-provider model registry",
	"license": "MIT",
	"author": "Victor Software House",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/victor-software-house/pi-openai-proxy.git"
	},
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"keywords": [
		"openai",
		"proxy",
		"pi-coding-agent",
		"pi-package",
		"llm",
		"gateway"
	],
	"pi": {
		"extensions": [
			"./extensions"
		]
	},
	"engines": {
		"node": ">=20"
	},
	"type": "module",
	"exports": {
		".": {
			"import": "./dist/index.mjs",
			"types": "./dist/index.d.mts"
		},
		"./config": {
			"import": "./dist/config.mjs",
			"types": "./dist/config.d.mts"
		},
		"./exposure": {
			"import": "./dist/exposure.mjs",
			"types": "./dist/exposure.d.mts"
		},
		"./sync/zed": {
			"import": "./dist/sync-zed.mjs",
			"types": "./dist/sync-zed.d.mts"
		}
	},
	"main": "dist/index.mjs",
	"bin": {
		"pi-openai-proxy": "dist/index.mjs"
	},
	"files": [
		"dist",
		"extensions"
	],
	"scripts": {
		"dev": "bun src/index.ts",
		"build": "tsdown",
		"start": "bun dist/index.mjs",
		"typecheck": "tsc --noEmit",
		"lint": "bun run lint:biome && bun run lint:oxlint",
		"lint:biome": "biome check .",
		"lint:oxlint": "oxlint --import-plugin --type-aware --tsconfig=./tsconfig.json .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"test": "bun test",
		"test:ci": "bun test test/unit/ test/integration/",
		"prepare": "tsdown",
		"prepack": "bun run build",
		"prepublishOnly": "bun test && bun run build"
	},
	"dependencies": {
		"@mariozechner/pi-ai": "^0.62.0",
		"@mariozechner/pi-coding-agent": "^0.62.0",
		"@sinclair/typebox": "^0.34.0",
		"citty": "^0.1.6",
		"hono": "^4.12.8",
		"jsonc-parser": "^3.3.1",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.8",
		"@commitlint/cli": "^20.5.0",
		"@commitlint/config-conventional": "^20.5.0",
		"@limegrass/eslint-plugin-import-alias": "^1.6.1",
		"@semantic-release/changelog": "^6.0.3",
		"@semantic-release/git": "^10.0.1",
		"@semantic-release/github": "^12.0.6",
		"@semantic-release/npm": "^13.1.5",
		"@types/bun": "^1.3.11",
		"@types/node": "^25.5.0",
		"eslint-plugin-zod": "^3.5.0",
		"lefthook": "^2.1.4",
		"openai": "^6.26.0",
		"oxlint": "^1.56.0",
		"oxlint-tsgolint": "^0.17.1",
		"semantic-release": "^25.0.3",
		"tsdown": "^0.21.4",
		"typescript": "^5.9.3"
	}
}
